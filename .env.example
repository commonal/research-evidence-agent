# The standalone baseline uses deterministic providers without API keys.
SEARCH_PROVIDER=demo
ANSWER_PROVIDER=demo
SEARCH_MAX_RESULTS=5

# Research workflow defaults remain deterministic and work without API keys.
RESEARCH_PAPER_PROVIDER=demo
ACADEMIC_QUERY_PLANNER=demo
RESEARCH_MAX_RESULTS_PER_QUERY=5

# Use RESEARCH_PAPER_PROVIDER=arxiv for live paper discovery.
ARXIV_API_URL=https://export.arxiv.org/api/query
ARXIV_MIN_INTERVAL_SECONDS=3

# Required only for ACADEMIC_QUERY_PLANNER=openai_compatible.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional business persistence. Run `uv run alembic upgrade head` before use.
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg://research:research@127.0.0.1:5432/research_evidence

